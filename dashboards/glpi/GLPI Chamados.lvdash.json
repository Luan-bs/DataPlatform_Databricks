    {
      "name": "9c8709c2",
      "displayName": "Total de Chamados",
      "queryLines": [
        "SELECT COUNT(*) AS Total\r\n",
        "FROM f_tickets\r\n",
        "WHERE deletado = FALSE"
      ],
      "catalog": "glpi",
      "schema": "gold_chamados"
    },
    {
      "name": "82693f58",
      "displayName": "Chamados Fechados",
      "queryLines": [
        "SELECT\r\n",
        "COUNT(f.ticket_id) AS Fechados\r\n",
        "FROM f_tickets f\r\n",
        "JOIN d_status d on f.status_id = d.status_id\r\n",
        "WHERE d.status_descricao = \"Chamado Fechado\" AND f.deletado = false"
      ],
      "catalog": "glpi",
      "schema": "gold_chamados"
    },
    {
      "name": "746eeb7a",
      "displayName": "Chamados Abertos",
      "queryLines": [
        "SELECT\r\n",
        "COUNT(ticket_id) AS Abertos\r\n",
        "FROM f_tickets \r\n",
        "WHERE status_id IN (4,2,3) AND deletado = false"
      ],
      "catalog": "glpi",
      "schema": "gold_chamados"
    },
    {
      "name": "fc1565fc",
      "displayName": "Positivos e Negativos",
      "queryLines": [
        "SELECT\r\n",
        "  ROUND(\r\n",
        "    SUM(CASE WHEN satisfaction >= 4 THEN 1 ELSE 0 END)\r\n",
        "    / COUNT(*)\r\n",
        "    ,2\r\n",
        "  ) AS Positivos,\r\n",
        "  SUM(CASE WHEN satisfaction >= 4 THEN 1 ELSE 0 END) AS Qtd_Positivos,\r\n",
        "  ROUND(\r\n",
        "    SUM(CASE WHEN satisfaction <= 3 THEN 1 ELSE 0 END)\r\n",
        "    / COUNT(*)\r\n",
        "    ,2\r\n",
        "  ) AS Negativos,\r\n",
        "  SUM(CASE WHEN satisfaction <= 3 THEN 1 ELSE 0 END) AS Qtd_Negativos\r\n",
        "FROM f_ticketsatisfactions\r\n",
        "WHERE satisfaction IS NOT NULL"
      ],
      "catalog": "glpi",
      "schema": "gold_chamados"
    },
    {
      "name": "6f76ad91",
      "displayName": "Chamados por Atendente",
      "queryLines": [
        "SELECT\r\n",
        "    u.nome_completo,\r\n",
        "    COUNT(*) AS Chamados\r\n",
        "FROM p_tickets_users tu\r\n",
        "JOIN d_users u\r\n",
        "ON tu.usuario_id = u.user_id\r\n",
        "WHERE tu.tipo_relacionamento = 'Técnico'\r\n",
        "GROUP BY u.nome_completo\r\n",
        "ORDER BY Chamados DESC"
      ],
      "catalog": "glpi",
      "schema": "gold_chamados"
    }
  ],
