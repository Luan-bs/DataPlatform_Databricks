    {
      "name": "ded33027",
      "displayName": "Tempo Médio de Resolução",
      "queryLines": [
        "-- Tempo Médio de Resolução\r\n",
        "SELECT\r\n",
        "\r\n",
        "    ROUND(AVG(horas_resolucao),2) AS horas_medias\r\n",
        "\r\n",
        "FROM workspace.glpi.f_tickets\r\n",
        "\r\n",
        "WHERE horas_resolucao IS NOT NULL;"
      ],
      "catalog": "workspace",
      "schema": "glpi"
    },
    {
      "name": "fb272e76",
      "displayName": "Tickets Criados por Dia",
      "queryLines": [
        "-- tickets Criados por Dia\r\n",
        "SELECT\r\n",
        "\r\n",
        "    DATE(data_criacao) AS data,\r\n",
        "    COUNT(*) AS quantidade\r\n",
        "\r\n",
        "FROM workspace.glpi.f_tickets\r\n",
        "\r\n",
        "GROUP BY DATE(data_criacao)\r\n",
        "\r\n",
        "ORDER BY data;"
      ]
    },
    {
      "name": "1692b744",
      "displayName": "Tickets por Prioridade",
      "queryLines": [
        "-- Tickets por Prioridade\r\n",
        "SELECT\r\n",
        "\r\n",
        "    priority,\r\n",
        "    COUNT(*) AS quantidade\r\n",
        "\r\n",
        "FROM workspace.glpi.f_tickets\r\n",
        "\r\n",
        "GROUP BY priority\r\n",
        "\r\n",
        "ORDER BY priority;"
      ]
    },
    {
      "name": "0de8324a",
      "displayName": "Tickets por Status",
      "queryLines": [
        "-- Tickets por Status\r\n",
        "SELECT\r\n",
        "\r\n",
        "    s.status_descricao,\r\n",
        "    COUNT(*) AS quantidade\r\n",
        "\r\n",
        "FROM workspace.glpi.f_tickets t\r\n",
        "\r\n",
        "INNER JOIN workspace.glpi.d_status s\r\n",
        "    ON t.status_id = s.status_id\r\n",
        "    \r\n",
        "WHERE t.deletado = false\r\n",
        "\r\n",
        "GROUP BY\r\n",
        "    s.status_descricao\r\n",
        "\r\n",
        "\r\n",
        "ORDER BY\r\n",
        "    quantidade DESC;"
      ]
    }
  ],
